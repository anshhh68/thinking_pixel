# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Render, Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/thinking_pixel"

# ─── Authentication ──────────────────────────────────────────────────────────
# MUST be at least 32 characters in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="CHANGE-ME-generate-a-strong-random-string-at-least-32-chars"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend URL (CORS + invite emails) ─────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── SMTP (for invite emails) ────────────────────────────────────────────────
# Gmail: use an App Password, NOT your account password.
# https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# ─── Admin Seed (required for first deploy) ──────────────────────────────────
# Used by `npm run seed:prod` to create the initial admin account.
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASS="CHANGE-ME-use-a-strong-password"
