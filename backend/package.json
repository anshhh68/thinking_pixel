{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/scripts/seed.js && node src/index.js",
    "dev": "node src/index.js",
    "postinstall": "prisma generate --schema src/prisma/schema.prisma && prisma db push --schema src/prisma/schema.prisma --accept-data-loss",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma --name init",
    "seed": "node src/prisma/seed.js",
    "seed:prod": "node src/scripts/seed.js",
    "test:api": "node src/scripts/test-api.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "prisma": "^5.22.0"
  }
}
